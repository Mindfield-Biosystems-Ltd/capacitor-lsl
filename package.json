{
  "name": "@mindfield/capacitor-lsl",
  "version": "1.0.0",
  "description": "Capacitor 7 plugin for Lab Streaming Layer (LSL) — stream biosignal data from mobile devices to LabRecorder or any LSL-compatible receiver",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "android/libs/",
    "android/proguard-rules.pro",
    "ios/Plugin/",
    "ios/liblsl.xcframework/",
    "ios/CapacitorPluginLSL.podspec",
    "dist/",
    "*.js",
    "*.ts"
  ],
  "author": "Mindfield Biosystems Ltd.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mindfield-Biosystems-Ltd/capacitor-lsl"
  },
  "bugs": {
    "url": "https://github.com/Mindfield-Biosystems-Ltd/capacitor-lsl/issues"
  },
  "keywords": [
    "capacitor",
    "capacitor-plugin",
    "lsl",
    "lab-streaming-layer",
    "labstreaminglayer",
    "biosignal",
    "biofeedback",
    "neurofeedback",
    "eda",
    "eeg",
    "emg",
    "ionic",
    "typescript",
    "mindfield"
  ],
  "scripts": {
    "verify": "npm run verify:web",
    "verify:web": "npm run build",
    "build": "npm run clean && tsc && rollup -c rollup.config.mjs",
    "clean": "rimraf ./dist",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "rimraf": "^6.0.0",
    "rollup": "^4.0.0",
    "typescript": "~5.6.0"
  },
  "peerDependencies": {
    "@capacitor/core": ">=7.0.0"
  },
  "capacitor": {
    "android": {
      "src": "android"
    },
    "ios": {
      "src": "ios"
    }
  }
}
